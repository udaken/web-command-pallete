{
  "manifest_version": 3,
  "name": "Web Command Palette",
	"homepage_url": "https://github.com/udaken/web-command-pallete",
  "version": "1.2.0",
  "description": "A command palette for web pages.",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Web Command Palette"
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/engine.js", "content/ui.js", "content/main.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["options/index.html", "options/main.js", "options/style.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "web-command-palette@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}